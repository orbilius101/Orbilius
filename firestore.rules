rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.user_type == 'admin';
    }
    
    function isTeacher() {
      return isAuthenticated() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.user_type == 'teacher';
    }
    
    function isStudent() {
      return isAuthenticated() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.user_type == 'student';
    }
    
    function isTeacherOfStudent(studentId) {
      let student = get(/databases/$(database)/documents/users/$(studentId)).data;
      return student.teacher_id == request.auth.uid;
    }
    
    // Users collection
    match /users/{userId} {
      // Allow get (single document read) if:
      // - User is reading their own data
      // - User is an admin
      // - User is a teacher reading their student
      allow get: if isOwner(userId) || isAdmin() || 
                    (isTeacher() && isTeacherOfStudent(userId));
      
      // Allow list (queries) if:
      // - User is an admin
      // - User is a teacher (results filtered by query constraints)
      // - User is a student (for their own queries)
      allow list: if isAdmin() || isTeacher() || isAuthenticated();
      
      // Users can update their own data
      // Admins can update any user
      allow update: if isOwner(userId) || isAdmin();
      
      // Only admins can create users (via admin panel)
      // Or system can create during signup
      allow create: if isAdmin() || !exists(/databases/$(database)/documents/users/$(userId));
      
      // Only admins can delete users
      allow delete: if isAdmin();
    }
    
    // Projects collection
    match /projects/{projectId} {
      // Students can read their own projects
      // Teachers can read projects assigned to them
      // Admins can read all projects
      allow read: if isAuthenticated() && (
        resource.data.student_id == request.auth.uid ||
        resource.data.teacher_id == request.auth.uid ||
        isAdmin()
      );
      
      // Students can create their own projects
      allow create: if isAuthenticated() && request.resource.data.student_id == request.auth.uid;
      
      // Students can update their own projects
      // Teachers can update projects assigned to them
      // Admins can update any project
      allow update: if isAuthenticated() && (
        resource.data.student_id == request.auth.uid ||
        resource.data.teacher_id == request.auth.uid ||
        isAdmin()
      );
      
      // Only admins can delete projects
      allow delete: if isAdmin();
    }
    
    // Project Steps collection
    match /project_steps/{stepId} {
      function getProject(projectId) {
        return get(/databases/$(database)/documents/projects/$(projectId)).data;
      }
      
      // Students can read their own project steps
      // Teachers can read steps for their assigned projects
      // Admins can read all steps
      allow read: if isAuthenticated() && (
        getProject(resource.data.project_id).student_id == request.auth.uid ||
        getProject(resource.data.project_id).teacher_id == request.auth.uid ||
        isAdmin()
      );
      
      // Students can create steps for their projects
      allow create: if isAuthenticated() && 
                      getProject(request.resource.data.project_id).student_id == request.auth.uid;
      
      // Students can update their own steps
      // Teachers can update steps for their projects (comments, status)
      allow update: if isAuthenticated() && (
        getProject(resource.data.project_id).student_id == request.auth.uid ||
        getProject(resource.data.project_id).teacher_id == request.auth.uid ||
        isAdmin()
      );
      
      // Only students and admins can delete steps
      allow delete: if isAuthenticated() && (
        getProject(resource.data.project_id).student_id == request.auth.uid ||
        isAdmin()
      );
    }
    
    // Submissions collection (legacy)
    match /submissions/{submissionId} {
      function getProject(projectId) {
        return get(/databases/$(database)/documents/projects/$(projectId)).data;
      }
      
      allow read: if isAuthenticated() && (
        getProject(resource.data.project_id).student_id == request.auth.uid ||
        getProject(resource.data.project_id).teacher_id == request.auth.uid ||
        isAdmin()
      );
      
      allow create: if isAuthenticated();
      
      allow update: if isAuthenticated() && (
        getProject(resource.data.project_id).student_id == request.auth.uid ||
        getProject(resource.data.project_id).teacher_id == request.auth.uid ||
        isAdmin()
      );
      
      allow delete: if isAdmin();
    }
    
    // Step Comments collection
    match /step_comments/{commentId} {
      function getProject(projectId) {
        return get(/databases/$(database)/documents/projects/$(projectId)).data;
      }
      
      // Students can read comments on their projects
      // Teachers can read comments on their assigned projects
      // Admins can read all comments
      allow read: if isAuthenticated() && (
        getProject(resource.data.project_id).student_id == request.auth.uid ||
        getProject(resource.data.project_id).teacher_id == request.auth.uid ||
        isAdmin()
      );
      
      // Only teachers and admins can create comments
      allow create: if isTeacher() || isAdmin();
      
      // Teachers can update their own comments
      // Admins can update any comment
      allow update: if isAuthenticated() && (
        resource.data.teacher_id == request.auth.uid ||
        isAdmin()
      );
      
      // Only admins can delete comments
      allow delete: if isAdmin();
    }
    
    // Settings collection (global app settings like theme)
    match /settings/{settingId} {
      // Anyone can read settings
      allow read: if true;
      
      // Only admins can write settings
      allow write: if isAdmin();
    }
    
    // Pending Invitations collection
    match /pending_invitations/{inviteId} {
      // Allow get (single document) if:
      // - User is an admin
      // - Unauthenticated users can lookup by invitation code (for signup flow)
      // - Authenticated users can read invitations where teacher_id matches their UID
      allow get: if isAdmin() || 
                    (isAuthenticated() && resource.data.teacher_id == request.auth.uid) ||
                    (!isAuthenticated() && resource.data.invitation_code != null);
      
      // Allow list (queries) if:
      // - User is an admin
      // - User is a teacher (results filtered by query constraints)
      allow list: if isAdmin() || isTeacher();
      
      // Admins can create any invitation
      // Teachers can create student invitations (with their teacher_id)
      allow create: if isAdmin() || 
                       (isAuthenticated() && 
                        request.resource.data.role == 'student' && 
                        request.resource.data.teacher_id == request.auth.uid);
      
      // Admins can update any invitation
      // Teachers can update their own invitations (teacher_id must remain the same)
      allow update: if isAdmin() || 
                       (isAuthenticated() && 
                        resource.data.teacher_id == request.auth.uid &&
                        request.resource.data.teacher_id == request.auth.uid);
      
      // Allow delete if admin, teacher (for their invitations), or if authenticated user's email matches
      allow delete: if isAdmin() || 
                       (isAuthenticated() && resource.data.teacher_id == request.auth.uid) ||
                       (isAuthenticated() && resource.data.email == request.auth.token.email);
    }
  }
}
